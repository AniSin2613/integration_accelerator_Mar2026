# ──────────────────────────────────────────────────
# Dependencies
# ──────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ──────────────────────────────────────────────────
# Build outputs
# ──────────────────────────────────────────────────
dist/
build/
.next/
out/

# ──────────────────────────────────────────────────
# Environment / secrets
# Keep real secrets local-only; allow example templates to stay tracked
# ──────────────────────────────────────────────────
.env
.env.*
.env.local
.env.*.local
.env.development
.env.development.local
.env.production
.env.production.local
.env.test
.env.test.local
.env.staging
.env.staging.local
.envrc
*.pem
*.key
*.p12
*.pfx
secrets/
.secrets/
!.env.example
!**/.env.example
!.env.sample
!**/.env.sample

# ──────────────────────────────────────────────────
# Prisma
# ──────────────────────────────────────────────────
apps/api/prisma/migrations/

# ──────────────────────────────────────────────────
# Editors & OS
# ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/settings.json

# ──────────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────────
*.log
npm-debug.log*
pnpm-debug.log*

# Dev script logs and PID files (generated by scripts/dev-start.sh)
logs/

# ──────────────────────────────────────────────────
# Test coverage
# ──────────────────────────────────────────────────
coverage/
.nyc_output/

# ──────────────────────────────────────────────────
# Typescript incremental cache
# ──────────────────────────────────────────────────
*.tsbuildinfo
