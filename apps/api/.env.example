# API environment variables
# Copy this to .env and set real values locally (never commit .env)

NODE_ENV=development
PORT=4000

# PostgreSQL connection
DATABASE_URL=postgresql://cogniviti:local_dev_password@localhost:5432/cogniviti_bridge

# Auth stub — replace with a real secret manager reference in production
AUTH_STUB_SECRET=dev_stub_secret_not_for_production

# Camel runner service URL
CAMEL_RUNNER_URL=http://localhost:8080
