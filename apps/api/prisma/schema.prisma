// Cogniviti Bridge — Prisma Schema
// Primary database: PostgreSQL
// Domains: IAM / Core tenancy / Design / Runtime / Reporting / Audit
//
// Immutability rules (from blueprint §15.5):
//   Mutable in place: users, memberships, connectionBindings, environmentOverrides, healthSnapshots
//   Versioned / immutable: templateVersions, approvedMappingSets, releaseArtifacts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════════════════════

enum EnvironmentType {
  DEV
  TEST
  PROD
}

enum UserRole {
  VIEWER
  BUILDER
  RELEASE_MANAGER
  ADMIN
  PLATFORM_ADMIN
}

enum TemplateClass {
  CERTIFIED
  STARTER
}

enum BusinessObject {
  VENDOR
  PURCHASE_ORDER
  INVOICE
  REQUISITION
  SUPPLIER
  SUPPLIER_INFORMATION
  LOOKUP
  LOOKUP_VALUE
  RECEIVING_TRANSACTION
  INVENTORY_TRANSACTION
  APPROVAL
  GENERIC
}

enum ConnectionFamily {
  REST_OPENAPI
  SFTP_FILE
  JDBC_SQL
  S3
  WEBHOOK
  SCHEDULER
}

enum IntegrationStatus {
  DRAFT
  IN_TEST
  LIVE
  ATTENTION_NEEDED
  PAUSED
}

enum ReadinessStatus {
  INCOMPLETE
  CONFIGURED
  VALIDATION_ISSUES
  TEST_FAILED
  TEST_PASSED
  READY_FOR_RELEASE_REVIEW
}

enum BuilderStatus {
  EDITING
  VALIDATING
  TESTING
  COMPLETE
}

enum ArtifactStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  DEPLOYED
}

enum MappingType {
  DIRECT
  CONSTANT
  DERIVED
  LOOKUP
  CONDITIONAL
}

enum MappingStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum RunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  RETRYING
  CANCELLED
}

enum DemoTargetType {
  JSON
  XML
}

enum IntegrationTestRunStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum ProfileDirection {
  SOURCE
  TARGET
}

enum BaselineProfileVersionStatus {
  DRAFT
  CURRENT
  DEPRECATED
  END_OF_SUPPORT
}

enum OverlayVersionStatus {
  DRAFT
  PUBLISHED
  SUPERSEDED
  ARCHIVED
}

enum EffectiveProfileStatus {
  ACTIVE
  UPDATE_AVAILABLE
  REVIEW_REQUIRED
  SUPERSEDED
}

enum ProfileUpdateStatus {
  UP_TO_DATE
  UPDATE_AVAILABLE
  REVIEW_REQUIRED
  END_OF_SUPPORT
  BLOCKED_BY_PROFILE_CHANGE
}

enum ProfileImpactLevel {
  NO_IMPACT
  INFORMATIONAL
  WARNING
  BLOCKING
}

enum ProfileChangeType {
  NEW_FIELD
  REMOVED_FIELD
  DEPRECATED_FIELD
  REQUIREDNESS_CHANGED
  TYPE_CHANGED
  PATH_CHANGED
}

enum ProfileNoticeStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

enum RebaseStatus {
  PENDING
  ANALYZED
  READY
  BLOCKED
  APPLIED
  CANCELLED
}

// ═══════════════════════════════════════════════════════════════════════════════
// CORE TENANCY
// ═══════════════════════════════════════════════════════════════════════════════

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaces     Workspace[]
  users          User[]
  businessEvents BusinessEvent[]
  auditLogs      AuditLog[]
}

model Workspace {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  slug      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant           Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  environments     Environment[]
  memberships      Membership[]
  connectionDefs   ConnectionDefinition[]
  integrationDefs  IntegrationDefinition[]
  releaseArtifacts ReleaseArtifact[]
  auditLogs        AuditLog[]
  profileOverlayVersions ProfileOverlayVersion[]
  effectiveProfileVersions EffectiveProfileVersion[]
  profileUpdateNotices ProfileUpdateNotice[]
  profileRebasePlans ProfileRebasePlan[]

  @@unique([tenantId, slug])
}

model Environment {
  id          String          @id @default(cuid())
  workspaceId String
  name        String?         // e.g. "Dev", "Test", "Prod" — derived from type if null
  type        EnvironmentType
  createdAt   DateTime        @default(now())

  workspace            Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  connectionBindings   ConnectionEnvBinding[]
  environmentReleases  EnvironmentRelease[]
  environmentOverrides EnvironmentOverride[]
  workflowRuns         WorkflowRun[]
  healthSnapshots      HealthSnapshot[]

  @@unique([workspaceId, type])
}

// ═══════════════════════════════════════════════════════════════════════════════
// IAM
// ═══════════════════════════════════════════════════════════════════════════════

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String   @unique
  name         String
  passwordHash String?  // nullable — future: delegate to IdP
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  memberships        Membership[]
  approvalRequests   ApprovalRequest[]  @relation("RequestedBy")
  reviewedApprovals  ApprovalRequest[]  @relation("ReviewedBy")
  replayRequests     ReplayRequest[]
  auditLogs          AuditLog[]
  supportTickets     SupportTicket[]
}

model Membership {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        UserRole
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// CONNECTIONS
// ═══════════════════════════════════════════════════════════════════════════════

model ConnectionDefinition {
  id          String           @id @default(cuid())
  workspaceId String
  name        String
  family      ConnectionFamily
  // Non-sensitive configuration (base URL pattern, auth scheme, schema).
  // Sensitive values (credentials) are stored in a secret manager;
  // only the reference key is held here.
  config      Json
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  // Soft-delete: non-null means the connection was removed by the user.
  // Kept for audit; hidden from all UI/API list queries.
  deletedAt   DateTime?

  workspace   Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  envBindings ConnectionEnvBinding[]
  testHistory ConnectionTestHistory[]
}

model ConnectionEnvBinding {
  id              String   @id @default(cuid())
  connectionDefId String
  environmentId   String
  // Reference key into the secret manager (e.g. AWS Secrets Manager ARN or Vault path).
  // NEVER store the raw credential here.
  secretRef       String?
  // Bounded operational overrides: base URL, token endpoint, etc.
  overrideConfig  Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  connectionDef ConnectionDefinition @relation(fields: [connectionDefId], references: [id], onDelete: Cascade)
  environment   Environment          @relation(fields: [environmentId], references: [id], onDelete: Restrict)

  @@unique([connectionDefId, environmentId])
}

model ConnectionTestHistory {
  id              String   @id @default(cuid())
  connectionDefId String
  environmentId   String
  success         Boolean
  testedAt        DateTime @default(now())
  errorMessage    String?

  connectionDef ConnectionDefinition @relation(fields: [connectionDefId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════════════════════
// DESIGN — TEMPLATES
// ═══════════════════════════════════════════════════════════════════════════════

model TemplateDefinition {
  id             String         @id @default(cuid())
  name           String
  description    String?
  class          TemplateClass
  sourceSystem   String?        // e.g. "Coupa", "GEP", "Generic"
  targetSystem   String?        // e.g. "SAP", "Dynamics", "Generic"
  businessObject BusinessObject
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  versions        TemplateVersion[]
  integrationDefs IntegrationDefinition[]
}

// Template versions are immutable once published.
model TemplateVersion {
  id                 String    @id @default(cuid())
  templateDefId      String
  version            String    // semver e.g. "1.0.0"
  // JSON describing the ordered workflow boxes and their allowed configuration.
  workflowStructure  Json
  // Suggested default mapping hints baked into the template.
  defaultMappings    Json?
  // Base Camel YAML route template with placeholders for connection/mapping values.
  camelRouteTemplate String?
  sourceProfileFamilyId String?
  sourceProfileVersionId String?
  targetProfileFamilyId String?
  targetProfileVersionId String?
  isLatest           Boolean   @default(false)
  publishedAt        DateTime?
  createdAt          DateTime  @default(now())

  templateDef     TemplateDefinition  @relation(fields: [templateDefId], references: [id], onDelete: Restrict)
  schemaPacks     SchemaPackBinding[]
  integrationDefs IntegrationDefinition[]
  sourceProfileFamily  ProfileFamily?  @relation("TemplateSourceProfileFamily", fields: [sourceProfileFamilyId], references: [id], onDelete: SetNull)
  sourceProfileVersion ProfileVersion? @relation("TemplateSourceProfileVersion", fields: [sourceProfileVersionId], references: [id], onDelete: SetNull)
  targetProfileFamily  ProfileFamily?  @relation("TemplateTargetProfileFamily", fields: [targetProfileFamilyId], references: [id], onDelete: SetNull)
  targetProfileVersion ProfileVersion? @relation("TemplateTargetProfileVersion", fields: [targetProfileVersionId], references: [id], onDelete: SetNull)

  @@unique([templateDefId, version])
}

// ═══════════════════════════════════════════════════════════════════════════════
// DESIGN — SCHEMA PACKS
// ═══════════════════════════════════════════════════════════════════════════════

model SchemaPack {
  id        String   @id @default(cuid())
  name      String   // e.g. "Coupa Invoice v1"
  system    String   // e.g. "Coupa"
  object    String   // e.g. "Invoice"
  version   String
  createdAt DateTime @default(now())

  fields         SchemaField[]
  bindings       SchemaPackBinding[]
  targetProfiles TargetProfile[]
}

model SchemaField {
  id           String  @id @default(cuid())
  schemaPackId String
  path         String  // e.g. "invoice.header.amount"
  dataType     String  // e.g. "String", "Decimal", "Date"
  required     Boolean @default(false)
  description  String?
  example      String?

  schemaPack SchemaPack @relation(fields: [schemaPackId], references: [id], onDelete: Cascade)
}

model SchemaPackBinding {
  id                String @id @default(cuid())
  templateVersionId String
  schemaPackId      String
  // "SOURCE" or "TARGET"
  role              String

  templateVersion TemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: Cascade)
  schemaPack      SchemaPack      @relation(fields: [schemaPackId], references: [id], onDelete: Restrict)

  @@unique([templateVersionId, schemaPackId, role])
}

// ═══════════════════════════════════════════════════════════════════════════════
// DESIGN — INTEGRATION DEFINITIONS
// ═══════════════════════════════════════════════════════════════════════════════

// An IntegrationDefinition is one live instance of a template within a workspace.
// e.g. "Coupa-to-SAP Invoice sync for ACME Procurement workspace"
model IntegrationDefinition {
  id                String            @id @default(cuid())
  workspaceId       String
  templateDefId     String
  templateVersionId String
  name              String
  status            IntegrationStatus @default(DRAFT)
  targetProfileId   String?
  pinnedSourceEffectiveProfileVersionId String?
  pinnedTargetEffectiveProfileVersionId String?
  sourceProfileUpdateStatus             ProfileUpdateStatus @default(UP_TO_DATE)
  targetProfileUpdateStatus             ProfileUpdateStatus @default(UP_TO_DATE)
  sourceSchemaHash                      String?
  targetSchemaHash                      String?
  sourceProfileImpactLevel              ProfileImpactLevel  @default(NO_IMPACT)
  targetProfileImpactLevel              ProfileImpactLevel  @default(NO_IMPACT)
  profileReviewRequired                 Boolean             @default(false)

  // ── Source / target connection references ──
  sourceConnectionId  String?
  targetConnectionId  String?

  // ── Draft state stored as JSON ──
  // Builder-level state persisted per save.
  validationState       Json?     // ValidationConfig: { rules, policyMode }
  responseHandlingState Json?     // ResponseHandlingConfig
  operationsState       Json?     // MonitoringConfig
  sourceState           Json?     // SourceGroupConfig
  targetState           Json?     // TargetGroupConfig
  triggerState          Json?     // TriggerConfig

  // ── Readiness lifecycle ──
  builderStatus    BuilderStatus   @default(EDITING)
  readinessStatus  ReadinessStatus @default(INCOMPLETE)
  draftVersion     Int             @default(1)
  lastTestStatus   String?         // 'success' | 'error'
  lastTestAt       DateTime?
  createdBy        String?
  updatedBy        String?

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  workspace       Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  templateDef     TemplateDefinition @relation(fields: [templateDefId], references: [id], onDelete: Restrict)
  templateVersion TemplateVersion    @relation(fields: [templateVersionId], references: [id], onDelete: Restrict)
  targetProfile   TargetProfile?     @relation(fields: [targetProfileId], references: [id], onDelete: SetNull)
  pinnedSourceEffectiveProfileVersion EffectiveProfileVersion? @relation("PinnedSourceEffectiveProfileVersion", fields: [pinnedSourceEffectiveProfileVersionId], references: [id], onDelete: SetNull)
  pinnedTargetEffectiveProfileVersion EffectiveProfileVersion? @relation("PinnedTargetEffectiveProfileVersion", fields: [pinnedTargetEffectiveProfileVersionId], references: [id], onDelete: SetNull)

  mappingSets      MappingSet[]
  releaseArtifacts ReleaseArtifact[]
  profileUpdateNotices ProfileUpdateNotice[]
  profileRebasePlans   ProfileRebasePlan[]
  testRuns             IntegrationTestRun[]
  demoTargetReceipts   DemoTargetReceipt[]
}

// ═══════════════════════════════════════════════════════════════════════════════
// DESIGN — MAPPINGS
// ═══════════════════════════════════════════════════════════════════════════════

// A MappingSet groups all field mapping rules for one integration at one point in time.
// On approval it becomes immutable (snapshotJson is captured).
model MappingSet {
  id               String    @id @default(cuid())
  integrationDefId String
  version          Int       @default(1)
  isApproved       Boolean   @default(false)
  approvedAt       DateTime?
  approvedByUserId String?
  // Immutable snapshot captured at approval time for reliable artifact packaging.
  snapshotJson     Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  integrationDef IntegrationDefinition @relation(fields: [integrationDefId], references: [id], onDelete: Restrict)
  rules          MappingRule[]
}

model MappingRule {
  id              String        @id @default(cuid())
  mappingSetId    String
  sourceField     String
  targetField     String
  mappingType     MappingType   @default(DIRECT)
  // Transform configuration (e.g. date format pattern, lookup table reference)
  transformConfig Json?
  status          MappingStatus @default(PENDING_REVIEW)
  // Position in the mapping list (0-based); controls display order.
  sortOrder       Int           @default(0)
  // AI suggestion metadata (zero-trust; requires human approval before use).
  // aiEvidenceSource stores one-or-many categories joined by "|":
  // INTERNAL_APPROVED, SOURCE_PLATFORM_OFFICIAL_DOCS,
  // TARGET_PLATFORM_OFFICIAL_DOCS, OFFICIAL_OPENAPI_SPEC,
  // OFFICIAL_FIELD_DICTIONARY, CURATED_SCHEMA_PACK
  aiConfidence    Decimal?
  aiEvidenceSource String?
  aiExplanation   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  mappingSet MappingSet @relation(fields: [mappingSetId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════════════════════
// DESIGN — RELEASE & PROMOTION
// ═══════════════════════════════════════════════════════════════════════════════

// A ReleaseArtifact is a point-in-time snapshot of everything needed to deploy
// an integration. Once approved it becomes immutable.
model ReleaseArtifact {
  id               String         @id @default(cuid())
  workspaceId      String
  integrationDefId String
  version          String         // e.g. "1.0.0", "1.1.0"
  // The complete generated Camel YAML route (stored as text for auditability)
  camelYaml        String
  // Full mapping state captured at release time
  mappingSnapshot  Json
  sourceEffectiveProfileVersionId String?
  targetEffectiveProfileVersionId String?
  sourceSchemaHash               String?
  targetSchemaHash               String?
  status           ArtifactStatus @default(DRAFT)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  workspace       Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  integrationDef  IntegrationDefinition @relation(fields: [integrationDefId], references: [id], onDelete: Restrict)
  sourceEffectiveProfileVersion EffectiveProfileVersion? @relation("ReleaseSourceEffectiveProfileVersion", fields: [sourceEffectiveProfileVersionId], references: [id], onDelete: SetNull)
  targetEffectiveProfileVersion EffectiveProfileVersion? @relation("ReleaseTargetEffectiveProfileVersion", fields: [targetEffectiveProfileVersionId], references: [id], onDelete: SetNull)

  environmentReleases EnvironmentRelease[]
  approvalRequests    ApprovalRequest[]
}

// Tracks which artifact is deployed to which environment.
model EnvironmentRelease {
  id                String    @id @default(cuid())
  releaseArtifactId String
  environmentId     String
  deployedAt        DateTime?
  deployedByUserId  String?
  createdAt         DateTime  @default(now())

  releaseArtifact ReleaseArtifact @relation(fields: [releaseArtifactId], references: [id], onDelete: Restrict)
  environment     Environment     @relation(fields: [environmentId], references: [id], onDelete: Restrict)

  @@unique([releaseArtifactId, environmentId])
}

// Bounded operational overrides — only allowed field keys are supported.
// Test and Prod cannot deviate from the promoted artifact structure.
model EnvironmentOverride {
  id            String   @id @default(cuid())
  environmentId String
  // Allowed keys: BASE_URL, TOKEN_ENDPOINT, CRON_EXPRESSION, WEBHOOK_URL,
  //   FILE_PATH, BUCKET_PATH, ALERT_RECIPIENTS, THROTTLE_LIMIT, CONCURRENCY
  key           String
  // Plain non-sensitive value (e.g. a base URL). Sensitive values use secretRef.
  value         String?
  // Reference to secret manager key — not the raw secret value.
  secretRef     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@unique([environmentId, key])
}

model ApprovalRequest {
  id                String         @id @default(cuid())
  releaseArtifactId String
  requestedByUserId String
  reviewedByUserId  String?
  status            ArtifactStatus @default(SUBMITTED)
  notes             String?
  reviewedAt        DateTime?
  createdAt         DateTime       @default(now())

  releaseArtifact ReleaseArtifact @relation(fields: [releaseArtifactId], references: [id], onDelete: Restrict)
  requestedBy     User            @relation("RequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  reviewedBy      User?           @relation("ReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
}

// ═══════════════════════════════════════════════════════════════════════════════
// RUNTIME TRACKING
// ═══════════════════════════════════════════════════════════════════════════════

model WorkflowRun {
  id               String    @id @default(cuid())
  environmentId    String
  integrationDefId String
  // Which artifact was active during this run (nullable during early scaffold)
  releaseArtifactId String?
  status           RunStatus @default(PENDING)
  // e.g. "SCHEDULE", "WEBHOOK", "MANUAL"
  trigger          String?
  startedAt        DateTime?
  completedAt      DateTime?
  durationMs       Int?
  recordsProcessed Int?
  errorCount       Int?
  createdAt        DateTime  @default(now())

  environment    Environment     @relation(fields: [environmentId], references: [id], onDelete: Restrict)
  runItems       RunItem[]
  replayRequests ReplayRequest[]
}

model RunItem {
  id            String    @id @default(cuid())
  workflowRunId String
  // Business-domain key for traceability (e.g. invoice number, PO number)
  businessKey   String?
  status        RunStatus
  errorMessage  String?
  // Structured failure reason for KPI reporting
  failureReason String?
  processedAt   DateTime?
  createdAt     DateTime  @default(now())

  workflowRun WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
}

model ReplayRequest {
  id                String    @id @default(cuid())
  workflowRunId     String
  requestedByUserId String
  status            RunStatus @default(PENDING)
  createdAt         DateTime  @default(now())

  workflowRun WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  requestedBy User        @relation(fields: [requestedByUserId], references: [id], onDelete: Restrict)
}

model HealthSnapshot {
  id               String   @id @default(cuid())
  environmentId    String
  uptimePct        Decimal?
  errorRatePct     Decimal?
  avgLatencyMs     Int?
  recordsProcessed Int?
  snapshotAt       DateTime @default(now())

  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
}

model IntegrationTestRun {
  id                             String                   @id @default(cuid())
  integrationDefId               String
  status                         IntegrationTestRunStatus
  sourceFetchStatus              String
  mappingStatus                  String
  validationStatus               String
  targetDeliveryStatus           String
  sourceConnectionId             String?
  targetConnectionId             String?
  targetType                     DemoTargetType
  targetName                     String
  draftVersion                   Int?
  sourceProfileEffectiveVersionId String?
  targetProfileEffectiveVersionId String?
  sourceSchemaHash               String?
  targetSchemaHash               String?
  sourcePayload                  Json?
  outboundPayloadJson            Json?
  outboundPayloadRaw             String?
  // Passed records delivered to target (subset of outbound when partial validation)
  passedPayloadJson              Json?
  // Failed records that did not pass validation (with per-record error details)
  failedPayloadJson              Json?
  validationErrors               Json?
  normalizedErrorSummary         String?
  targetResponseStatusCode       Int?
  targetResponseBody             String?
  targetResponseHeaders          Json?
  requestRef                     String?
  responseRef                    String?
  createdAt                      DateTime                 @default(now())

  integrationDef IntegrationDefinition @relation(fields: [integrationDefId], references: [id], onDelete: Cascade)
  receipts       DemoTargetReceipt[]

  @@index([integrationDefId, createdAt])
}

model DemoTargetReceipt {
  id                       String         @id @default(cuid())
  targetType               DemoTargetType
  targetName               String
  mode                     String         @default("success")
  integrationDefId         String?
  testRunId                String?
  requestHeaders           Json?
  requestContentType       String?
  rawRequestBody           String
  parsedJsonBody           Json?
  responseStatusCode       Int
  rawResponseBody          String
  responseHeaders          Json?
  createdAt                DateTime       @default(now())

  integrationDef IntegrationDefinition? @relation(fields: [integrationDefId], references: [id], onDelete: SetNull)
  testRun       IntegrationTestRun?     @relation(fields: [testRunId], references: [id], onDelete: SetNull)

  @@index([targetType, targetName, createdAt])
  @@index([integrationDefId, createdAt])
  @@index([testRunId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// REPORTING — Business Event Ledger
// ═══════════════════════════════════════════════════════════════════════════════

// The business event ledger powers KPI reports separately from low-level run logs.
// This is a V1 differentiator: ready-made reportable facts, not just raw logs.
model BusinessEvent {
  id             String         @id @default(cuid())
  tenantId       String
  workspaceId    String
  integrationId  String
  // e.g. "INVOICE_PROCESSED", "VENDOR_SYNCED", "PO_CREATED"
  eventType      String
  businessObject BusinessObject
  // The business-domain key (e.g. invoice number, vendor ID)
  businessKey    String?
  success        Boolean
  processingMs   Int?
  occurredAt     DateTime       @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
}

// ═══════════════════════════════════════════════════════════════════════════════
// AUDIT LOG
// ═══════════════════════════════════════════════════════════════════════════════

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  workspaceId String?
  userId      String?
  // Structured action label (e.g. "MAPPING_APPROVED", "RELEASE_DEPLOYED")
  action      String
  entityType  String?
  entityId    String?
  // Contextual details — kept minimal; no raw payloads
  details     Json?
  createdAt   DateTime @default(now())

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// ═══════════════════════════════════════════════════════════════════════════════
// DESIGN — TARGET PROFILES
// ═══════════════════════════════════════════════════════════════════════════════

enum OverlayType {
  FIELD_ALIAS
  VALIDATION_RULE
  DEFAULT_VALUE
  FIELD_VISIBILITY
  CUSTOM_TRANSFORM
}

enum DriftSuggestionType {
  NEW_FIELD
  DEPRECATED_FIELD
  TYPE_CHANGE
  CONSTRAINT_CHANGE
}

enum DriftSuggestionStatus {
  NEW
  IN_REVIEW
  APPROVED
  REJECTED
  CONVERTED_CONDITIONAL
}

enum RuntimeIssueType {
  MISSING_REQUIRED_FIELD
  UNKNOWN_FIELD
  INVALID_TYPE_OR_FORMAT
  FORBIDDEN_VALUE
  BUSINESS_RULE_REJECTION
  AUTH_OR_PERMISSION_ISSUE
  TARGET_CONTRACT_MISMATCH
  UNKNOWN_TARGET_ERROR
}

enum DriftSuggestedChange {
  MARK_CUSTOMER_REQUIRED
  MARK_CONDITIONAL
  REVIEW_UNKNOWN_FIELD
  REVIEW_FIELD_TYPE
  REVIEW_FIELD_VISIBILITY
}

// A TargetProfile is a curated, organization-specific view of a target schema.
// It layers business-friendly naming, validation rules, defaults, and visibility
// on top of a base SchemaPack.
model TargetProfile {
  id               String    @id @default(cuid())
  schemaPackId     String
  system           String    // e.g. "SAP", "Dynamics"
  object           String    // e.g. "Invoice", "Vendor"
  name             String
  description      String?
  isPublished      Boolean   @default(false)
  currentVersionId String?   @unique
  profileFamilyId  String?   @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  schemaPack      SchemaPack           @relation(fields: [schemaPackId], references: [id], onDelete: Restrict)
  currentVersion  TargetProfileVersion? @relation("CurrentVersion", fields: [currentVersionId], references: [id])
  profileFamily   ProfileFamily?       @relation(fields: [profileFamilyId], references: [id], onDelete: SetNull)
  fields          TargetProfileField[]
  overlays        TargetProfileOverlay[]
  versions        TargetProfileVersion[] @relation("ProfileVersions")
  driftSuggestions DriftSuggestion[]
  integrations    IntegrationDefinition[]
}

model TargetProfileField {
  id              String   @id @default(cuid())
  targetProfileId String
  path            String   // mirrors SchemaField.path
  dataType        String
  required        Boolean  @default(false)
  businessName    String?  // friendly label for business users
  description     String?
  validationRule  String?  // e.g. regex or expression
  defaultValue    String?
  example         String?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  targetProfile TargetProfile @relation(fields: [targetProfileId], references: [id], onDelete: Cascade)

  @@unique([targetProfileId, path])
}

model TargetProfileOverlay {
  id              String      @id @default(cuid())
  targetProfileId String
  overlayType     OverlayType
  // Overlay payload — schema depends on overlayType:
  //   FIELD_ALIAS:       { fieldPath, alias }
  //   VALIDATION_RULE:   { fieldPath, rule }
  //   DEFAULT_VALUE:     { fieldPath, value }
  //   FIELD_VISIBILITY:  { fieldPath, visible }
  //   CUSTOM_TRANSFORM:  { fieldPath, expression }
  config          Json
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  targetProfile TargetProfile @relation(fields: [targetProfileId], references: [id], onDelete: Cascade)
}

// Target profile versions are immutable once published.
model TargetProfileVersion {
  id              String    @id @default(cuid())
  targetProfileId String
  version         String    // semver e.g. "1.0.0"
  snapshotJson    Json      // complete profile + fields + overlays at publish time
  publishedAt     DateTime  @default(now())
  createdAt       DateTime  @default(now())

  targetProfile       TargetProfile @relation("ProfileVersions", fields: [targetProfileId], references: [id], onDelete: Cascade)
  currentOfProfile    TargetProfile? @relation("CurrentVersion")

  @@unique([targetProfileId, version])
}

model DriftSuggestion {
  id              String                @id @default(cuid())
  targetProfileId String
  fieldPath       String
  suggestionType  DriftSuggestionType
  // Details about the detected drift (e.g. old type, new type, added field metadata)
  details         Json
  isApplied       Boolean               @default(false)
  createdAt       DateTime              @default(now())

  // ── Runtime drift review fields ──────────────────────────────────────────
  status            DriftSuggestionStatus @default(NEW)
  observedIssueType RuntimeIssueType?
  suggestedChange   DriftSuggestedChange?
  confidence        Decimal?              @db.Decimal(3, 2) // 0.00 – 1.00
  environment       String?               // e.g. "DEV", "TEST", "PROD"
  // Evidence references (stored as opaque refs, not raw payloads)
  requestRef        String?               // reference to the request that produced this issue
  responseRef       String?               // reference to the response
  rawErrorExcerpt   String?               @db.Text
  sourceRunRef      String?               // workflow run or test-run ID
  // Review workflow
  reviewerNote      String?               @db.Text
  reviewedBy        String?               // user ID of reviewer
  reviewedAt        DateTime?
  // Overlay created on approval
  overlayId         String?               // overlay created when approved
  versionId         String?               // profile version created on approval
  updatedAt         DateTime              @updatedAt

  targetProfile TargetProfile @relation(fields: [targetProfileId], references: [id], onDelete: Cascade)

  @@index([targetProfileId, status])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════════════════════════
// DESIGN — GENERIC PROFILE REGISTRY (SOURCE + TARGET)
// ═══════════════════════════════════════════════════════════════════════════════

model ProfileFamily {
  id               String           @id @default(cuid())
  direction        ProfileDirection
  system           String
  interfaceName    String
  object           String?
  platformOwned    Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  baselineVersions    ProfileVersion[]
  overlayVersions     ProfileOverlayVersion[]
  effectiveVersions   EffectiveProfileVersion[]
  sourceTemplateRefs  TemplateVersion[] @relation("TemplateSourceProfileFamily")
  targetTemplateRefs  TemplateVersion[] @relation("TemplateTargetProfileFamily")
  targetProfileLegacy TargetProfile?

  @@unique([direction, system, interfaceName])
}

model ProfileVersion {
  id                 String                       @id @default(cuid())
  profileFamilyId    String
  version            String
  status             BaselineProfileVersionStatus @default(DRAFT)
  schemaSnapshot     Json
  schemaHash         String?
  publishedAt        DateTime?
  deprecatedAt       DateTime?
  endOfSupportAt     DateTime?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  profileFamily      ProfileFamily               @relation(fields: [profileFamilyId], references: [id], onDelete: Cascade)
  overlayVersions    ProfileOverlayVersion[]
  effectiveVersions  EffectiveProfileVersion[]
  sourceTemplateRefs TemplateVersion[] @relation("TemplateSourceProfileVersion")
  targetTemplateRefs TemplateVersion[] @relation("TemplateTargetProfileVersion")
  oldRebasePlans     ProfileRebasePlan[] @relation("OldBaselineProfileVersion")
  newRebasePlans     ProfileRebasePlan[] @relation("NewBaselineProfileVersion")

  @@unique([profileFamilyId, version])
  @@index([profileFamilyId, status])
  @@index([status, endOfSupportAt])
}

model ProfileOverlayVersion {
  id                      String               @id @default(cuid())
  profileFamilyId         String
  baselineProfileVersionId String
  workspaceId             String
  version                 String
  status                  OverlayVersionStatus @default(DRAFT)
  overlayDelta            Json
  schemaHash              String?
  publishedAt             DateTime?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  profileFamily           ProfileFamily        @relation(fields: [profileFamilyId], references: [id], onDelete: Cascade)
  baselineProfileVersion  ProfileVersion       @relation(fields: [baselineProfileVersionId], references: [id], onDelete: Restrict)
  workspace               Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  effectiveVersions       EffectiveProfileVersion[]
  rebasePlans             ProfileRebasePlan[]

  @@unique([workspaceId, profileFamilyId, version])
  @@index([profileFamilyId, workspaceId, status])
}

model EffectiveProfileVersion {
  id                      String                 @id @default(cuid())
  profileFamilyId         String
  baselineProfileVersionId String
  overlayVersionId        String?
  workspaceId             String?
  status                  EffectiveProfileStatus @default(ACTIVE)
  effectiveSchemaSnapshot Json
  schemaHash              String
  publishedAt             DateTime?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  profileFamily                 ProfileFamily          @relation(fields: [profileFamilyId], references: [id], onDelete: Cascade)
  baselineProfileVersion        ProfileVersion         @relation(fields: [baselineProfileVersionId], references: [id], onDelete: Restrict)
  overlayVersion                ProfileOverlayVersion? @relation(fields: [overlayVersionId], references: [id], onDelete: SetNull)
  workspace                     Workspace?             @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  pinnedAsSourceBy              IntegrationDefinition[] @relation("PinnedSourceEffectiveProfileVersion")
  pinnedAsTargetBy              IntegrationDefinition[] @relation("PinnedTargetEffectiveProfileVersion")
  releaseAsSourceBy             ReleaseArtifact[]      @relation("ReleaseSourceEffectiveProfileVersion")
  releaseAsTargetBy             ReleaseArtifact[]      @relation("ReleaseTargetEffectiveProfileVersion")
  noticesAsPinned               ProfileUpdateNotice[]  @relation("NoticePinnedEffectiveProfileVersion")
  noticesAsLatest               ProfileUpdateNotice[]  @relation("NoticeLatestEffectiveProfileVersion")
  rebaseCandidates              ProfileRebasePlan[]    @relation("RebaseCandidateEffectiveProfileVersion")

  @@index([profileFamilyId, workspaceId, status])
  @@index([status])
}

model ProfileUpdateNotice {
  id                              String              @id @default(cuid())
  workspaceId                     String
  integrationDefId                String?
  direction                       ProfileDirection
  pinnedEffectiveProfileVersionId String?
  latestEffectiveProfileVersionId String?
  impactLevel                     ProfileImpactLevel  @default(NO_IMPACT)
  status                          ProfileNoticeStatus @default(OPEN)
  blockingReason                  String?
  summary                         String?
  details                         Json?
  createdAt                       DateTime            @default(now())
  updatedAt                       DateTime            @updatedAt

  workspace                       Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  integrationDef                  IntegrationDefinition?  @relation(fields: [integrationDefId], references: [id], onDelete: Cascade)
  pinnedEffectiveProfileVersion   EffectiveProfileVersion? @relation("NoticePinnedEffectiveProfileVersion", fields: [pinnedEffectiveProfileVersionId], references: [id], onDelete: SetNull)
  latestEffectiveProfileVersion   EffectiveProfileVersion? @relation("NoticeLatestEffectiveProfileVersion", fields: [latestEffectiveProfileVersionId], references: [id], onDelete: SetNull)
  changes                         ProfileImpactChange[]

  @@index([workspaceId, status, impactLevel])
  @@index([integrationDefId])
}

model ProfileImpactChange {
  id            String             @id @default(cuid())
  noticeId      String
  changeType    ProfileChangeType
  fieldPath     String
  oldValue      String?
  newValue      String?
  impactLevel   ProfileImpactLevel @default(INFORMATIONAL)

  notice        ProfileUpdateNotice @relation(fields: [noticeId], references: [id], onDelete: Cascade)

  @@index([noticeId, impactLevel])
}

model ProfileRebasePlan {
  id                               String              @id @default(cuid())
  workspaceId                      String
  integrationDefId                 String
  direction                        ProfileDirection
  oldBaselineProfileVersionId      String
  newBaselineProfileVersionId      String
  currentOverlayVersionId          String?
  candidateEffectiveProfileVersionId String?
  impactLevel                      ProfileImpactLevel  @default(NO_IMPACT)
  status                           RebaseStatus        @default(PENDING)
  impactSummary                    Json?
  candidateMappingPatch            Json?
  createdAt                        DateTime            @default(now())
  updatedAt                        DateTime            @updatedAt

  workspace                        Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  integrationDef                   IntegrationDefinition @relation(fields: [integrationDefId], references: [id], onDelete: Cascade)
  oldBaselineProfileVersion        ProfileVersion       @relation("OldBaselineProfileVersion", fields: [oldBaselineProfileVersionId], references: [id], onDelete: Restrict)
  newBaselineProfileVersion        ProfileVersion       @relation("NewBaselineProfileVersion", fields: [newBaselineProfileVersionId], references: [id], onDelete: Restrict)
  currentOverlayVersion            ProfileOverlayVersion? @relation(fields: [currentOverlayVersionId], references: [id], onDelete: SetNull)
  candidateEffectiveProfileVersion EffectiveProfileVersion? @relation("RebaseCandidateEffectiveProfileVersion", fields: [candidateEffectiveProfileVersionId], references: [id], onDelete: SetNull)

  @@index([workspaceId, integrationDefId, direction])
  @@index([status])
}

model SupportTicket {
  id        String   @id @default(cuid())
  userId    String?
  name      String?
  email     String?
  subject   String
  message   String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}
