{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "paths": {
      "@cogniviti/domain": ["../domain/src"]
    }
  },
  "references": [
    { "path": "../domain" }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
