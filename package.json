{
  "name": "cogniviti-bridge",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "build": "pnpm run --filter './apps/*' build && pnpm run --filter './packages/*' build",
    "lint": "pnpm run --recursive lint",
    "test": "./scripts/test-all.sh",
    "test:fast": "./scripts/test-all.sh --skip-types",
    "test:offline": "./scripts/test-all.sh --skip-types --skip-api",
    "verify:preview:compile": "./scripts/verify-preview-compile.sh",
    "verify:preview:runtime": "./scripts/verify-preview-runtime.sh",
    "db:generate": "pnpm --filter @cogniviti/api exec prisma generate",
    "db:migrate:dev": "pnpm --filter @cogniviti/api exec prisma migrate dev",
    "db:migrate:deploy": "pnpm --filter @cogniviti/api exec prisma migrate deploy",
    "db:seed": "pnpm --filter @cogniviti/api exec ts-node prisma/seed.ts",
    "db:studio": "pnpm --filter @cogniviti/api exec prisma studio"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "@nestjs/core"
    ]
  }
}
